# Database (DigitalOcean Managed PostgreSQL)
DATABASE_URL="postgresql://user:password@host:25060/defaultdb?sslmode=require"

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# DigitalOcean Spaces (S3-compatible file storage)
DO_SPACES_KEY=""
DO_SPACES_SECRET=""
DO_SPACES_BUCKET="dochat"
DO_SPACES_REGION="sgp1"
DO_SPACES_ENDPOINT="https://dochat.sgp1.digitaloceanspaces.com"

# DigitalOcean Gradient AI
DIGITALOCEAN_API_TOKEN=""
DO_PROJECT_ID=""                                    # DigitalOcean project ID
DO_AGENT_REGION="tor1"                              # Region for agents/KBs
DO_AGENT_MODEL_UUID=""                              # Foundation model UUID (from /v2/gen-ai/models)
DO_EMBEDDING_MODEL_UUID=""                          # Embedding model UUID (from /v2/gen-ai/models)

# Optional: Vapi Voice
VAPI_API_KEY=""

# Optional: Widget URL (for embed script integration snippets)
NEXT_PUBLIC_WIDGET_URL="https://your-dochat-widget.ondigitalocean.app"
