{
  "name": "@dochat/web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "mkdir -p node_modules/.prisma && ln -sf $(realpath ../../node_modules/.prisma/client) node_modules/.prisma/client 2>/dev/null || true",
    "dev": "dotenv -e ../../.env -- next dev --port 3005",
    "build": "dotenv -e ../../.env -- next build",
    "start": "dotenv -e ../../.env -- next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@clerk/nextjs": "^6.12.0",
    "@dochat/db": "workspace:*",
    "@dochat/shared": "workspace:*",
    "@hookform/resolvers": "^5.2.0",
    "@tanstack/react-query": "^5.65.0",
    "@workspace/ui": "workspace:*",
    "bowser": "^2.12.0",
    "countries-and-timezones": "^3.8.0",
    "date-fns": "^4.1.0",
    "jotai": "^2.12.5",
    "lucide-react": "^0.475.0",
    "next": "^15.2.3",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.61.1",
    "sonner": "^2.0.6",
    "svix": "^1.42.0",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "^5.7.3"
  }
}
